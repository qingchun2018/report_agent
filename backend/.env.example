MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=report_agent
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 生产环境建议配置（可选）
# 英文逗号分隔的前端来源，用于 CORS；不配则允许所有来源（仅建议开发）
# ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5175
# 是否暴露 /docs 与 /redoc，生产可关闭
# DOCS_ENABLED=false

# 鉴权（注册/登录/JWT）
# 生产环境务必改为强随机字符串，例如 python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please_change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
# Token 过期时间（分钟），默认 7 天
JWT_EXPIRE_MINUTES=10080
